{
  "layout": "flow",
  "title": {
    "main": "Refund Review Flow",
    "subtitle": "Submit, gate on policy, retry with evidence, ship"
  },
  "canvas": {
    "width": 1210,
    "height": 1000
  },
  "nodes": [
    {"id": "submit", "label": "Submit request", "body": "User files a refund with order id", "kind": "start"},
    {"id": "triage", "label": "Auto triage", "body": "Dedupe, attach order history"},
    {"id": "gate", "label": "Passes policy?", "kind": "decision"},
    {"id": "fix", "label": "Request evidence", "body": "Ask for receipt or photos", "lane": "right"},
    {"id": "ship", "label": "Refund issued", "kind": "end"}
  ],
  "edges": [
    {"from": "submit", "to": "triage"},
    {"from": "triage", "to": "gate"},
    {"from": "gate", "to": "ship", "label": "yes"},
    {"from": "gate", "to": "fix", "label": "no"},
    {"from": "fix", "to": "triage", "kind": "retry", "label": "resubmit"}
  ]
}
